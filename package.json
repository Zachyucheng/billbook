{
  "name": "billbook",
  "version": "2.41.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "build": "cd web && npm run build && mkdir -p ../out && cp -r out/* ../out/",
    "build:web": "cd web && npm run build",
    "desktop:dev": "node scripts/desktop-dev.js",
    "desktop:start": "npm run build && electron .",
    "mcp:billbook": "node desktop/mcp/billbook-server.mjs",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:mac": "npm run build && electron-builder --mac --x64",
    "pack:all": "npm run build && electron-builder --win --mac --x64",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.billbook.desktop",
    "productName": "Billbook",
    "directories": {
      "output": "dist-electron",
      "buildResources": "desktop/resources"
    },
    "files": [
      "desktop/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "desktop/resources/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "desktop/resources/icon.png",
      "category": "public.app-category.finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "unicode": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "sql.js": "^1.13.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "electron": "^38.3.0",
    "electron-builder": "^26.8.1",
    "wrangler": "^4.87.0"
  }
}
